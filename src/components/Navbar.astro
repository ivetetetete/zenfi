---
import { LogOut } from "@lucide/astro";
---

<div id="container" class="bg-white p-5 min-h-screen w-56 shadow fixed bottom-0 left-0 top-0">
    <h1>Zenfi</h1>
    Hola, <span id="user-name">...</span> 👋
    <div class="flex flex-col gap-y-3 mt-5">
        <a href=""> Inicio </a>
        <a href=""> Configurar </a>
        <a href=""> Categorias </a>
        <a href=""> Transacciones </a>
    </div>

    <a href="" class="flex flex-row items-center gap-x-2 mt-5">
        <LogOut class="w-5 h-5" color="#000" />
        <p>Cerrar sesión</p>
    </a>
</div>

<script>
    // cerrar sesión
    import { signOut } from "firebase/auth";
    import { auth } from "../firebase/clients";
    import { $user } from "../store/userStore";

    const nameElement = document.getElementById("user-name");

    // Nos suscribimos a los cambios del store
    $user.subscribe((user: { name?: string } | null) => {
        if (user && nameElement) {
            nameElement.textContent = user.name || "Usuario";
        } else {
            // Si no hay usuario, mandarlo al login
            // window.location.href = "/auth";
        }
    });

    const logoutLink = document.querySelector(
        'a[href=""]',
    ) as HTMLAnchorElement;
    logoutLink.addEventListener("click", (e) => {
        e.preventDefault();
        signOut(auth)
            .then(() => {
                // Sign-out successful.
                window.location.href = "/auth"; // Redirige al login después de cerrar sesión
            })
            .catch((error) => {
                // An error happened.
                console.error("Error al cerrar sesión:", error);
            });
    });
</script>
