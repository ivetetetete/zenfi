---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import GeneralProgressBar from "../components/GeneralProgressBar.astro";
import { Plus, ArrowUpRight, ArrowDownLeft, X } from "@lucide/astro";
---

<DashboardLayout title="Transacciones | Zenfi">
  <div class="max-w-2xl mx-auto w-full space-y-8 pb-24">
    <div
      class="bg-white rounded-3xl p-6 border border-zenfi-sand shadow-sm text-center"
    >
      <div id="budget-content" class="hidden">
        <GeneralProgressBar
          id="transactions-gauge"
          label="Balance Mensual"
          percentage={0}
        />
      </div>
      <div
        id="budget-loading"
        class="py-10 animate-pulse text-zenfi-taupe font-medium"
      >
        Calculando balance...
      </div>
    </div>

    <div class="flex flex-col gap-4 mt-3">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-black text-zenfi-brown">Movimientos</h2>
        <button
          class="bg-zenfi-terra text-white p-2 rounded-full shadow-lg hover:scale-105 transition-transform"
          id="add-transaction-btn"
        >
          <Plus class="w-6 h-6" />
        </button>
      </div>

      <div
        class="flex bg-zenfi-sand/30 p-1 rounded-2xl border border-zenfi-sand mb-2"
      >
        <button
          id="show-expenses"
          class="flex-1 py-2 rounded-xl font-bold text-sm transition-all bg-white text-zenfi-brown shadow-sm"
        >
          Gastos
        </button>
        <button
          id="show-income"
          class="flex-1 py-2 rounded-xl font-bold text-sm transition-all text-zenfi-taupe hover:text-zenfi-brown"
        >
          Ingresos
        </button>
      </div>
    </div>

    <div id="transactions-list" class="space-y-3">
      <div class="animate-pulse space-y-3">
        <div class="h-20 bg-white rounded-2xl border border-zenfi-sand"></div>
        <div class="h-20 bg-white rounded-2xl border border-zenfi-sand"></div>
      </div>
    </div>
  </div>

  <div
    id="modal-overlay"
    class="fixed inset-0 z-[110] hidden items-end md:items-center justify-center bg-black/20 backdrop-blur-sm"
  >
    <div
      id="modal-sheet"
      class="absolute bottom-0 w-full md:relative md:bottom-auto md:w-auto md:max-w-md bg-white rounded-2xl p-8 z-[120] shadow-[0_8px_40px_rgba(0,0,0,0.18)] translate-y-full md:translate-y-0 md:opacity-0 transition-all duration-300"
    >
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-black text-zenfi-brown">Nueva Transacción</h3>
        <button
          id="close-modal"
          class="text-zenfi-taupe hover:text-zenfi-brown transition-colors p-1 rounded-full hover:bg-zenfi-sand/40"
        >
          <X class="w-5 h-5" />
        </button>
      </div>

      <form id="transaction-form" class="space-y-5">
        <div class="flex bg-zenfi-sand/40 p-1 rounded-2xl">
          <button
            type="button"
            id="type-expense"
            class="flex-1 py-2 rounded-xl font-bold text-sm transition-all bg-white text-zenfi-brown shadow-sm"
            >Gasto</button
          >
          <button
            type="button"
            id="type-income"
            class="flex-1 py-2 rounded-xl font-bold text-sm transition-all text-zenfi-taupe hover:text-zenfi-brown"
            >Ingreso</button
          >
        </div>
        <input type="hidden" id="transaction-type" value="expense" />

        <div id="category-select-container">
          <label
            class="block text-[10px] font-extrabold text-zenfi-taupe uppercase mb-1 ml-2"
            >Categoría</label
          >
          <select
            id="transaction-category"
            class="w-full bg-zenfi-cream border-none rounded-2xl py-4 px-4 font-bold text-zenfi-brown focus:ring-2 focus:ring-zenfi-terra/20 appearance-none"
          >
            <option value="" disabled selected>Selecciona una categoría</option>
          </select>
        </div>

        <div>
          <label
            class="block text-[10px] font-extrabold text-zenfi-taupe uppercase mb-1 ml-2"
            >Monto</label
          >
          <div class="relative">
            <span
              class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-zenfi-brown text-xl"
              id="modal-currency"></span>
            <input
              type="number"
              id="transaction-amount"
              step="0.01"
              required
              placeholder="0.00"
              class="w-full bg-zenfi-cream border-none rounded-2xl py-4 pl-10 pr-4 text-2xl font-black text-zenfi-brown focus:ring-2 focus:ring-zenfi-terra/20"
            />
          </div>
        </div>

        <div>
          <label
            class="block text-[10px] font-extrabold text-zenfi-taupe uppercase mb-1 ml-2"
            >Descripción</label
          >
          <input
            type="text"
            id="transaction-description"
            required
            placeholder="Ej. Supermercado"
            class="w-full bg-zenfi-cream border-none rounded-2xl py-4 px-4 font-bold text-zenfi-brown focus:ring-2 focus:ring-zenfi-terra/20"
          />
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-zenfi-brown text-white py-4 rounded-2xl font-black text-lg active:scale-[0.98] transition-transform"
        >
          Guardar Transacción
        </button>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth, db } from "../firebase/clients";
  import { onAuthStateChanged } from "firebase/auth";
  import {
    doc,
    getDoc,
    collection,
    addDoc,
    updateDoc,
    increment,
    serverTimestamp,
    query,
    orderBy,
    getDocs,
    where,
  } from "firebase/firestore";

  let currentUserId: string | null = null;
  let currentView = "expenses";
  let transactionItems: any[] = [];

  interface FinancialProfile {
    currency: string;
    monthlyIncome: number;
    totalFixedExpenses: number;
    totalExpenses: number;
    balance: number;
    fixedExpensesDetail?: { name: string; amount: number; icon?: string }[];
    categories?: { name: string; icon?: string; budget: number }[];
  }

  let profileData: FinancialProfile | null = null;

  onAuthStateChanged(auth, async (user) => {
    if (!user) {
      window.location.href = "/auth";
      return;
    }
    currentUserId = user.uid;
    await loadProfile();
    await fetchTransactions();
  });

  async function loadProfile() {
    if (!currentUserId) return;
    try {
      const userDoc = await getDoc(doc(db, "users", currentUserId));
      if (userDoc.exists()) {
        profileData = userDoc.data().financialProfile;
        updateUI();
        populateCategorySelect();
      }
    } catch (e) {
      console.error("Error loading profile:", e);
    }
  }

  async function fetchTransactions() {
    if (!currentUserId) return;
    try {
      const transRef = collection(db, "users", currentUserId, "transactions");
      const q = query(transRef, orderBy("createdAt", "desc"));
      const querySnapshot = await getDocs(q);
      transactionItems = querySnapshot.docs.map((doc) => ({
        id: doc.id,
        ...doc.data(),
      }));
      renderList();
    } catch (e) {
      console.error("Error fetching transactions:", e);
    }
  }

  function populateCategorySelect() {
    const select = document.getElementById(
      "transaction-category",
    ) as HTMLSelectElement;
    if (!select || !profileData?.categories) return;

    // Clear and add placeholder
    select.innerHTML =
      '<option value="" disabled selected>Selecciona una categoría</option>';

    // Add user-defined categories
    profileData.categories.forEach((cat) => {
      const option = document.createElement("option");
      option.value = cat.name;
      option.textContent = `${cat.icon || "📦"} ${cat.name}`;
      select.appendChild(option);
    });

    // Add the "Other" option manually
    const otherOption = document.createElement("option");
    otherOption.value = "Otro";
    otherOption.textContent = "⚙️ Otro";
    select.appendChild(otherOption);
  }

  // --- Modal Visibility Logic ---
  const typeExpense = document.getElementById("type-expense");
  const typeIncome = document.getElementById("type-income");
  const typeInput = document.getElementById(
    "transaction-type",
  ) as HTMLInputElement;
  const categoryContainer = document.getElementById(
    "category-select-container",
  );

  const setType = (type: "expense" | "income") => {
    typeInput.value = type;
    const ACTIVE =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all bg-white text-zenfi-brown shadow-sm";
    const INACTIVE =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all text-zenfi-taupe hover:text-zenfi-brown";

    if (type === "expense") {
      typeExpense!.className = ACTIVE;
      typeIncome!.className = INACTIVE;
      categoryContainer?.classList.remove("hidden");
    } else {
      typeIncome!.className = ACTIVE;
      typeExpense!.className = INACTIVE;
      categoryContainer?.classList.add("hidden");
    }
  };

  typeExpense?.addEventListener("click", () => setType("expense"));
  typeIncome?.addEventListener("click", () => setType("income"));

  // --- Form Submission ---
  const form = document.getElementById("transaction-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!currentUserId || !submitBtn) return;

    const type = typeInput.value;
    const amount = parseFloat(
      (document.getElementById("transaction-amount") as HTMLInputElement).value,
    );
    const desc = (
      document.getElementById("transaction-description") as HTMLInputElement
    ).value;
    const categoryName = (
      document.getElementById("transaction-category") as HTMLSelectElement
    ).value;
    const selectedCategory = profileData?.categories?.find(
      (c) => c.name === categoryName,
    );

    let iconToSave = "💸";
    if (type === "income") {
      iconToSave = "📈";
    } else if (categoryName === "Otro") {
      iconToSave = "⚙️";
    } else if (selectedCategory) {
      iconToSave = selectedCategory.icon || "📦";
    }

    const originalText = submitBtn.textContent;
    submitBtn.textContent = "Procesando...";
    (submitBtn as HTMLButtonElement).disabled = true;

    try {
      const userRef = doc(db, "users", currentUserId);
      const transRef = collection(db, "users", currentUserId, "transactions");

      await addDoc(transRef, {
        type,
        amount,
        description: desc,
        category: type === "expense" ? categoryName : "Income",
        icon: iconToSave,
        createdAt: serverTimestamp(),
      });

      const updatePayload: any = {};
      if (type === "expense") {
        updatePayload["financialProfile.totalExpenses"] = increment(amount);
        updatePayload["financialProfile.balance"] = increment(-amount);
      } else {
        updatePayload["financialProfile.balance"] = increment(amount);
      }

      await updateDoc(userRef, updatePayload);

      submitBtn.textContent = "¡Guardado! ✅";
      setTimeout(async () => {
        hideModal();
        form.reset();
        setType(typeInput.value as "expense" | "income");
        submitBtn.textContent = originalText;
        (submitBtn as HTMLButtonElement).disabled = false;
        await loadProfile();
        await fetchTransactions();
      }, 1000);
    } catch (error) {
      console.error(error);
      submitBtn.textContent = "Error ❌";
    }
  });

  // --- UI Update & Rendering ---
  function updateUI() {
    if (!profileData) return;

    const cur = profileData.currency === "EUR" ? "€" : "$";
    const currencySym = document.getElementById("modal-currency");
    if (currencySym) currencySym.textContent = cur;

    const income = profileData.monthlyIncome || 0;
    const fixedOut = profileData.totalFixedExpenses || 0;
    const variableOut = profileData.totalExpenses || 0;
    const totalOut = fixedOut + variableOut;

    const container = document.getElementById("budget-content");
    document.getElementById("budget-loading")?.classList.add("hidden");
    container?.classList.remove("hidden");

    const percentage = Math.min(Math.round((totalOut / income) * 100), 100);
    const progressCircle = container?.querySelector(
      "circle:last-of-type",
    ) as SVGCircleElement;
    if (progressCircle) {
      const semiCirc = ((70 - 24) * 2 * Math.PI) / 2;
      progressCircle.style.strokeDashoffset = `${semiCirc - (percentage / 100) * semiCirc}`;
    }

    const amountText = container?.querySelector(".bar-amount-text");
    const percText = container?.querySelector(".bar-percentage-text");
    if (amountText)
      amountText.textContent = `${totalOut}${cur} / ${income}${cur}`;
    if (percText) percText.textContent = `${percentage}%`;

    renderList();
  }

  function renderList() {
    const list = document.getElementById("transactions-list");
    if (!list || !profileData) return;
    const cur = profileData.currency === "EUR" ? "€" : "$";

    let displayItems = [];
    if (currentView === "expenses") {
      const fixed = (profileData.fixedExpensesDetail || []).map((f) => ({
        ...f,
        isFixed: true,
        type: "expense",
      }));
      const variable = transactionItems.filter((t) => t.type === "expense");
      displayItems = [...fixed, ...variable];
    } else {
      displayItems = transactionItems.filter((t) => t.type === "income");
    }

    if (displayItems.length === 0) {
      list.innerHTML = `<p class="text-center py-10 text-zenfi-taupe font-medium">No hay movimientos.</p>`;
      return;
    }

    list.innerHTML = displayItems
      .map(
        (item) => `
    <div class="flex items-center justify-between bg-white p-4 rounded-2xl border border-zenfi-sand shadow-sm transition-all active:scale-[0.98]">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 flex items-center justify-center bg-zenfi-cream rounded-xl text-2xl">
          ${item.icon || (item.type === "income" ? "📈" : "💸")}
        </div>
        <div>
          <p class="font-bold text-zenfi-brown">${item.name || item.description}</p>
          <p class="text-[10px] font-extrabold text-zenfi-taupe uppercase tracking-widest">
            ${item.isFixed ? "Gasto Fijo" : item.category || "Transacción"}
          </p>
        </div>
      </div>
      <div class="text-right">
        <p class="font-black ${item.type === "income" ? "text-zenfi-sage" : "text-zenfi-terra"} text-lg">
          ${item.type === "income" ? "+" : "-"}${item.amount}${cur}
        </p>
      </div>
    </div>
  `,
      )
      .join("");
  }

  // --- Modal State Management ---
  const addBtn = document.getElementById("add-transaction-btn");
  const modalOverlay = document.getElementById("modal-overlay");
  const modalSheet = document.getElementById("modal-sheet");
  const closeModal = document.getElementById("close-modal");

  const hideModal = () => {
    modalOverlay?.classList.add("hidden");
    modalOverlay?.classList.remove("flex");
    document.body.style.overflow = "";
  };

  addBtn?.addEventListener("click", () => {
    modalOverlay?.classList.remove("hidden");
    modalOverlay?.classList.add("flex");
    void modalOverlay?.offsetWidth;
    modalSheet?.classList.remove("translate-y-full", "md:opacity-0");
    modalSheet?.classList.add("md:opacity-100");
    document.body.style.overflow = "hidden";
  });

  closeModal?.addEventListener("click", hideModal);

  // Toggle View
  const expBtn = document.getElementById("show-expenses");
  const incBtn = document.getElementById("show-income");

  expBtn?.addEventListener("click", () => {
    currentView = "expenses";
    expBtn.className =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all bg-white text-zenfi-brown shadow-sm";
    incBtn!.className =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all text-zenfi-taupe hover:text-zenfi-brown";
    renderList();
  });

  incBtn?.addEventListener("click", () => {
    currentView = "income";
    incBtn.className =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all bg-white text-zenfi-brown shadow-sm";
    expBtn!.className =
      "flex-1 py-2 rounded-xl font-bold text-sm transition-all text-zenfi-taupe hover:text-zenfi-brown";
    renderList();
  });
</script>

<style>
  @reference "../styles/global.css";
  @media (min-width: 768px) {
    #modal-sheet {
      transition:
        opacity 0.25s ease,
        transform 0.25s ease;
    }
    #modal-overlay {
      transition: background 0.25s ease;
    }
  }
</style>
